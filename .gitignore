# ===========================================================================
# ES_Drone_Thesis — publish-for-clone .gitignore
# Goal: ship a RUNNABLE workspace (model weights + thesis + figures + code).
# Exclude only junk and heavy/raw/regenerable artifacts.
# (Replaces the old ES_Drone_Detection-inherited ignore that blocked
#  models/, *.pt, *.joblib, *.csv, *.pdf — those are now intentionally tracked.)
# ===========================================================================

# --- Python / env / build ---
__pycache__/
*.py[cod]
*$py.class
*.so
.env
.venv/
venv/
env/
ENV/
build/
dist/
*.egg-info/
*.egg

# --- IDE / OS / logs ---
.idea/
.vscode/
*.iml
*.log
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/
node_modules/
bash.exe.stackdump

# --- Claude / local session + private dev instructions (now untracked) ---
.claude/
CLAUDE.md

# --- Raw datasets (live on G:/drone; not needed to run the GUI/thesis) ---
datasets/

# --- Videos (test/demo media; large, not needed to run) ---
*.mp4
*.avi
*.mov
*.mkv
*.wmv
*.flv
*.webm
*.part

# --- Regenerable run outputs / caches (rebuilt from models + G:/drone data) ---
**/demo_outputs/
gui/saved_alert_windows/
eval/results/
eval/cache/
thesis_eval/cache/
thesis_eval/cache_conf005/
mri/results/
classifier/runs/
notebooks/cache/
notebooks/figures/

# --- HITL label-reviewer session outputs (the tool itself IS tracked) ---
label_reviewer/.cache/
label_reviewer/.last_session.json
label_reviewer/review_*/
label_reviewer/compare_labels_*/
label_reviewer/roboflow_*/

# --- Backups / scratch local state ---
*.bak
*.bak_*
youtube_cookies.txt
.review_progress.json

# --- Patch-verifier TRAINING CROPS (raw/regenerable; ~128k tiny files, long paths).
#     The deployable patch WEIGHTS (models/patches/*.pt) and OOD calibration ARE kept. ---
models/patches/ir/
models/patches/ir_synth_review/
models/patches/rgb/
models/patches/rgb_synth_review/

# --- Granular ablation dumps (regenerable; deep paths hit Windows MAX_PATH 260).
#     Dashboard CSVs in docs/analysis/full_pipeline_ablations/csv/ stay tracked. ---
docs/analysis/full_pipeline_ablations/csvs/
docs/analysis/full_pipeline_ablations/raw_results/
*.stackdump

# NOTE: model weights (*.pt / *.joblib), KB/data CSVs, JSON configs, thesis
# PDFs + figures (docs/**), and Markdown are INTENTIONALLY tracked.
# Do NOT add blanket *.pt / *.csv / *.pdf ignores here.

# ===========================================================================
# Publish reorganization (2026-06-20): private / dev / regenerable trees that
# are kept ON DISK for development but NOT published. The companion repo ships
# only what the thesis cites + the closure needed to run and audit it.
# ===========================================================================
knowledge/                 # private knowledge system (not needed to run/audit)
archive/                   # old code snapshots
analytics/                 # legacy exploratory analysis
notebooks/                 # exploratory Jupyter
scratch/                   # scratch work
tests/                     # dev smoke tests (not cited)
check.txt
check2.txt
buildscript.log
generate_professor_plots.py
thesis_style.py            # only used by the (untracked) docs/ figure generators
docs/_appendices_bak_*.tex
docs/_emdash_bak_*/
docs/_ledger_strip_bak_*/

# The 7 audit-cited result files under the ignored eval/results|mri/results trees
# are force-added (git add -f) so the audit is reproducible on a fresh clone.


# knowledge-dependent appendix generator (reads the private knowledge base)
docs/gen_models_appendix.py

# ===========================================================================
# Model weights are NOT published (large). Contact the author for the trained
# weights and the datasets. Model cards (*.yaml), configs, and the small router
# feature tables (*.csv) stay tracked so the audit and eval.py work on a clone.
# ===========================================================================
*.pt
*.pth
*.joblib
*.onnx
*.engine
*.rar

# Local production-model export bundle (weights; share privately, do not publish)
models/_production_export/
