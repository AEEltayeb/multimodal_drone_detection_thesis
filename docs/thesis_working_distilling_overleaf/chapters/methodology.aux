\@writefile{toc}{\contentsline {subsection}{\numberline {3.8.1}Overview}{49}{subsection.3.8.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3.10}{\ignorespaces Multi-stage drone detection pipeline in the production composition: detectors, then the trust classifier, then the confuser filter. The order itself was ablated (Section~\ref {sec:pipeline_ablation}): classifier-first is the recall-safe choice, within a point of the alternative. The production confuser filter is the distilled \texttt  {mlp\_v5}, which runs \textbf  {per frame} because it reuses the detectors' already-computed ROI features rather than re-processing crops (Section~\ref {sec:distill_verifier}). It supersedes the MobileNetV3 patch filter (greyed), which was expensive enough that it had to be \emph  {alert-gated}: consulted only when the temporal smoother was about to fire (Section~\ref {sec:alert_gate}).}}{51}{figure.caption.27}\protected@file@percent }
\newlabel{fig:pipeline}{{3.10}{51}{Multi-stage drone detection pipeline in the production composition: detectors, then the trust classifier, then the confuser filter. The order itself was ablated (Section~\ref {sec:pipeline_ablation}): classifier-first is the recall-safe choice, within a point of the alternative. The production confuser filter is the distilled \texttt {mlp\_v5}, which runs \textbf {per frame} because it reuses the detectors' already-computed ROI features rather than re-processing crops (Section~\ref {sec:distill_verifier}). It supersedes the MobileNetV3 patch filter (greyed), which was expensive enough that it had to be \emph {alert-gated}: consulted only when the temporal smoother was about to fire (Section~\ref {sec:alert_gate})}{figure.caption.27}{}}
\@writefile{toc}{\contentsline {paragraph}{Two-filter fusion (trust-first).}{51}{paragraph*.29}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {3.11}{\ignorespaces The confuser problem, and why a downstream filter solves it. \emph  {Left}: the production RGB detector (\texttt  {ft4}) fires on a bird amid its flock (red box, detector confidence $0.46$). \emph  {Right}: it fires on a drone (confidence $0.85$). The detector cannot tell them apart, but the feature-reuse filter reads the detector's own ROI features and assigns $P(\text  {drone})=0.00$ to the bird (vetoed) and $0.96$ to the drone (kept). This separation, not a better detector, is what the cascade provides.}}{52}{figure.caption.28}\protected@file@percent }
\newlabel{fig:confuser_problem}{{3.11}{52}{The confuser problem, and why a downstream filter solves it. \emph {Left}: the production RGB detector (\texttt {ft4}) fires on a bird amid its flock (red box, detector confidence $0.46$). \emph {Right}: it fires on a drone (confidence $0.85$). The detector cannot tell them apart, but the feature-reuse filter reads the detector's own ROI features and assigns $P(\text {drone})=0.00$ to the bird (vetoed) and $0.96$ to the drone (kept). This separation, not a better detector, is what the cascade provides}{figure.caption.28}{}}
