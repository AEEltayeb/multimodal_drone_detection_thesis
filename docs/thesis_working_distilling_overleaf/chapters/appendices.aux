\@writefile{toc}{\contentsline {chapter}{\numberline {G}Full Per-Surface Ablation Tables}{93}{appendix.G}\protected@file@percent }
\@writefile{lof}{\addvspace {10\p@ }}
\@writefile{lot}{\addvspace {10\p@ }}
\newlabel{app:full_ablation}{{G}{93}{Full Per-Surface Ablation Tables}{appendix.G}{}}
\@writefile{lot}{\contentsline {table}{\numberline {G.1}{\ignorespaces Full-pipeline ablation, Svanstr\"om paired ($n=4{,}000$ frames, even-strided across the full 28{,}710-frame set, not the first $4{,}000$; RGB @1280 / IR @640, IoP@0.5). \emph  {RGB only}/\emph  {IR only} score that detector alone against its own ground truth; every row below the second rule is trust-aware and \emph  {sums both modalities} (RGB-side scored vs RGB GT $+$ IR-side vs IR GT), so its TP/FP/FN base is both modalities' drones combined, not the frame count. \texttt  {clf} $=$ $+$trust router; \texttt  {filt} $=$ $+$per-frame filter; \texttt  {clf$\to $filt} $=$ router then filter. The shipped production cell is \texttt  {filt$\to $clf[robust8-nr]} (filter then the no-reject router; \texttt  {robust8} with the reject class is the adjacent ablation, Section~\ref {sec:classifier_results}); the pipeline \emph  {raises} recall over bare ($0.948\to 0.991$) while adding $\sim $29~pp precision. \texttt  {clf$\to $filt} is the same router in the other order (Section~\ref {sec:classifier_results} on why \texttt  {filt$\to $clf} is shipped).}}{93}{table.caption.108}\protected@file@percent }
\newlabel{tab:ablation_svanstrom}{{G.1}{93}{Full-pipeline ablation, Svanstr\"om paired ($n=4{,}000$ frames, even-strided across the full 28{,}710-frame set, not the first $4{,}000$; RGB @1280 / IR @640, IoP@0.5). \emph {RGB only}/\emph {IR only} score that detector alone against its own ground truth; every row below the second rule is trust-aware and \emph {sums both modalities} (RGB-side scored vs RGB GT $+$ IR-side vs IR GT), so its TP/FP/FN base is both modalities' drones combined, not the frame count. \texttt {clf} $=$ $+$trust router; \texttt {filt} $=$ $+$per-frame filter; \texttt {clf$\to $filt} $=$ router then filter. The shipped production cell is \texttt {filt$\to $clf[robust8-nr]} (filter then the no-reject router; \texttt {robust8} with the reject class is the adjacent ablation, Section~\ref {sec:classifier_results}); the pipeline \emph {raises} recall over bare ($0.948\to 0.991$) while adding $\sim $29~pp precision. \texttt {clf$\to $filt} is the same router in the other order (Section~\ref {sec:classifier_results} on why \texttt {filt$\to $clf} is shipped)}{table.caption.108}{}}
\@writefile{lot}{\contentsline {table}{\numberline {G.2}{\ignorespaces Full-pipeline ablation, Anti-UAV paired ($n=4{,}000$ frames, even-strided across the 85{,}374-frame set, both modalities @640, IoU@0.5). Row conventions as in Table~\ref {tab:ablation_svanstrom} (\emph  {RGB/IR only} score one detector vs its own GT; the trust-aware rows sum both modalities). The no-harm control: every pipeline cell is within $\sim $1~pp of bare or above it, the shipped no-reject \texttt  {robust8-nr} included (this saturated surface rarely rejects, so dropping the reject class changes nothing here).}}{94}{table.caption.109}\protected@file@percent }
\newlabel{tab:ablation_antiuav}{{G.2}{94}{Full-pipeline ablation, Anti-UAV paired ($n=4{,}000$ frames, even-strided across the 85{,}374-frame set, both modalities @640, IoU@0.5). Row conventions as in Table~\ref {tab:ablation_svanstrom} (\emph {RGB/IR only} score one detector vs its own GT; the trust-aware rows sum both modalities). The no-harm control: every pipeline cell is within $\sim $1~pp of bare or above it, the shipped no-reject \texttt {robust8-nr} included (this saturated surface rarely rejects, so dropping the reject class changes nothing here)}{table.caption.109}{}}
\@writefile{lot}{\contentsline {table}{\numberline {G.3}{\ignorespaces Full-pipeline ablation, DUT Anti-UAV \emph  {test split} ($n=2{,}200$ frames, $2{,}245$ GT drones, RGB \texttt  {ft4} $+$ grayscale-IR \texttt  {v3b}, both @960, IoU@0.5, trust-aware). The grayscale-IR channel is the IR detector's no-thermal \emph  {fallback} mode (thermal model on grayscale RGB), not its native thermal performance. The full test split is used (not strided). Row conventions as in Table~\ref {tab:ablation_svanstrom} (\emph  {RGB/IR only} score one detector vs its own GT; the trust-aware rows sum both modalities). Confuser-free (all-drone): filters can only delete true positives, so here the pipeline buys precision, not FP suppression. \texttt  {filt$\to $clf[robust8-nr]} (the shipped no-reject router) is the production configuration; dropping the reject class recovers the recall \texttt  {robust8} surrenders on this clean surface (at \texttt  {filt$\to $clf}, $R\,0.574\to 0.800$, F1 $0.702\to 0.835$).}}{94}{table.caption.110}\protected@file@percent }
\newlabel{tab:ablation_dut}{{G.3}{94}{Full-pipeline ablation, DUT Anti-UAV \emph {test split} ($n=2{,}200$ frames, $2{,}245$ GT drones, RGB \texttt {ft4} $+$ grayscale-IR \texttt {v3b}, both @960, IoU@0.5, trust-aware). The grayscale-IR channel is the IR detector's no-thermal \emph {fallback} mode (thermal model on grayscale RGB), not its native thermal performance. The full test split is used (not strided). Row conventions as in Table~\ref {tab:ablation_svanstrom} (\emph {RGB/IR only} score one detector vs its own GT; the trust-aware rows sum both modalities). Confuser-free (all-drone): filters can only delete true positives, so here the pipeline buys precision, not FP suppression. \texttt {filt$\to $clf[robust8-nr]} (the shipped no-reject router) is the production configuration; dropping the reject class recovers the recall \texttt {robust8} surrenders on this clean surface (at \texttt {filt$\to $clf}, $R\,0.574\to 0.800$, F1 $0.702\to 0.835$)}{table.caption.110}{}}
\@writefile{lot}{\contentsline {table}{\numberline {G.4}{\ignorespaces Confuser-surface FP reduction. RGB confusers: $n=2{,}633$ (full test split) @640. IR confusers: $n=4{,}000$ of 5{,}237 (even spread) @640. Fire $=$ fraction of frames with $\geq $1 surviving detection. The shipped \texttt  {filt$\to $clf[robust8-nr]} equals \texttt  {filt only (mlp)} (and equals \texttt  {clf$\to $filt[robust8-nr]} to the digit, since a no-reject router never vetoes a confuser frame, so composition order is immaterial here); the \texttt  {robust8} ablation reaches $0.0011$ (RGB) by adding the reject net, the suppression the shipped stack trades for recall.}}{95}{table.caption.111}\protected@file@percent }
\newlabel{tab:ablation_confusers}{{G.4}{95}{Confuser-surface FP reduction. RGB confusers: $n=2{,}633$ (full test split) @640. IR confusers: $n=4{,}000$ of 5{,}237 (even spread) @640. Fire $=$ fraction of frames with $\geq $1 surviving detection. The shipped \texttt {filt$\to $clf[robust8-nr]} equals \texttt {filt only (mlp)} (and equals \texttt {clf$\to $filt[robust8-nr]} to the digit, since a no-reject router never vetoes a confuser frame, so composition order is immaterial here); the \texttt {robust8} ablation reaches $0.0011$ (RGB) by adding the reject net, the suppression the shipped stack trades for recall}{table.caption.111}{}}
\@writefile{lot}{\contentsline {table}{\numberline {G.5}{\ignorespaces Solo-surface ablation (single modality vs own GT). IR test split: $n=4{,}000$ of 9{,}612; RGB test split: $n=4{,}000$ of 17{,}209; SelCom: full 311. The \texttt  {clf} rows show the router on a single live channel: the reject-class \texttt  {robust8} collapses recall (it routes against a dead second modality), while the shipped no-reject \texttt  {robust8-nr} degrades gracefully to the bare detector, which is why single-modality deployments can run the full router. The filter's in-distribution recall cost is the honest counterweight to its OOD benefit.}}{95}{table.caption.112}\protected@file@percent }
\newlabel{tab:ablation_solo}{{G.5}{95}{Solo-surface ablation (single modality vs own GT). IR test split: $n=4{,}000$ of 9{,}612; RGB test split: $n=4{,}000$ of 17{,}209; SelCom: full 311. The \texttt {clf} rows show the router on a single live channel: the reject-class \texttt {robust8} collapses recall (it routes against a dead second modality), while the shipped no-reject \texttt {robust8-nr} degrades gracefully to the bare detector, which is why single-modality deployments can run the full router. The filter's in-distribution recall cost is the honest counterweight to its OOD benefit}{table.caption.112}{}}
