\@writefile{toc}{\contentsline {paragraph}{The shipped router: dropping the reject class.}{64}{paragraph*.65}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{The grayscale hole, and why the reject class caused it.}{65}{paragraph*.66}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.5}{\ignorespaces Design-history: the grayscale \texttt  {trust\_rgb} hole was a decision-rule problem inside the four-class router, not a feature-space limit. Sweeping the per-class \texttt  {trust\_rgb} threshold $\tau $ trades precision for recall along a well-separated curve; the reject-class \texttt  {robust8} operated at $\tau {=}0.20$. The shipped \texttt  {robust8-nr} drops the reject class and removes this knob entirely (the hole cannot form without a \texttt  {reject} label). Source: \texttt  {eval/compare\_routing\_pipeline.py}.}}{65}{figure.caption.67}\protected@file@percent }
\newlabel{fig:robust8_operating}{{4.5}{65}{Design-history: the grayscale \texttt {trust\_rgb} hole was a decision-rule problem inside the four-class router, not a feature-space limit. Sweeping the per-class \texttt {trust\_rgb} threshold $\tau $ trades precision for recall along a well-separated curve; the reject-class \texttt {robust8} operated at $\tau {=}0.20$. The shipped \texttt {robust8-nr} drops the reject class and removes this knob entirely (the hole cannot form without a \texttt {reject} label). Source: \texttt {eval/compare\_routing\_pipeline.py}}{figure.caption.67}{}}
\@writefile{toc}{\contentsline {paragraph}{A dual-classifier extension (validated, not shipped).}{65}{paragraph*.68}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Design evolution: the OOD confuser zoo (predecessor configuration).}{66}{paragraph*.69}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.6}{\ignorespaces No trust classifier wins both surfaces. On the OOD confuser zoo \texttt  {fusion\_no\_fn\_v1.1} is far the safest (S2 fire $0.016$) but on real video it collapses drone $F1$ to $0.219$; \texttt  {sa32} inverts the ranking, dominating real-video drone $F1$ ($0.826$) at a higher zoo fire ($0.205$). This surface reversal motivated the \texttt  {sa32} working pick, later superseded by the statistically-derived \texttt  {robust6}/\texttt  {robust8} (Section~\ref {sec:feature_selection}) and the shipped no-reject \texttt  {robust8-nr} (Section~\ref {sec:classifier_results}); \texttt  {sa32}'s scene-statistic leakage is why even its wins here are not trusted to generalise.}}{66}{figure.caption.70}\protected@file@percent }
\newlabel{fig:classifier_reversal}{{4.6}{66}{No trust classifier wins both surfaces. On the OOD confuser zoo \texttt {fusion\_no\_fn\_v1.1} is far the safest (S2 fire $0.016$) but on real video it collapses drone $F1$ to $0.219$; \texttt {sa32} inverts the ranking, dominating real-video drone $F1$ ($0.826$) at a higher zoo fire ($0.205$). This surface reversal motivated the \texttt {sa32} working pick, later superseded by the statistically-derived \texttt {robust6}/\texttt {robust8} (Section~\ref {sec:feature_selection}) and the shipped no-reject \texttt {robust8-nr} (Section~\ref {sec:classifier_results}); \texttt {sa32}'s scene-statistic leakage is why even its wins here are not trusted to generalise}{figure.caption.70}{}}
\@writefile{toc}{\contentsline {paragraph}{The surface reversal.}{66}{paragraph*.71}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {4.2}Model MRI Findings}{67}{section.4.2}\protected@file@percent }
\newlabel{sec:mri_findings}{{4.2}{67}{Model MRI Findings}{section.4.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.7}{\ignorespaces Model MRI of the FT4 detector's fused \texttt  {p3}+\texttt  {p5} features on the shipped $32{,}931$-detection corpus. (a) The linear-discriminant projection separates drone (blue) from confuser (red) into two cleanly-resolved peaks at $\approx 95\%$ single-threshold accuracy. (b) Per-block ANOVA $F$-statistic: \texttt  {p5} is the dominant discriminative layer (max $F=42{,}346$, median $657$), ahead of \texttt  {p3} and the detection metadata; the confidence scalar ranks only 6th.}}{67}{figure.caption.72}\protected@file@percent }
\newlabel{fig:mri_stats}{{4.7}{67}{Model MRI of the FT4 detector's fused \texttt {p3}+\texttt {p5} features on the shipped $32{,}931$-detection corpus. (a) The linear-discriminant projection separates drone (blue) from confuser (red) into two cleanly-resolved peaks at $\approx 95\%$ single-threshold accuracy. (b) Per-block ANOVA $F$-statistic: \texttt {p5} is the dominant discriminative layer (max $F=42{,}346$, median $657$), ahead of \texttt {p3} and the detection metadata; the confidence scalar ranks only 6th}{figure.caption.72}{}}
\@writefile{toc}{\contentsline {paragraph}{The signal is linear, supervised, and deep.}{67}{paragraph*.73}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{The instrument audits its own paper trail.}{67}{paragraph*.75}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.8}{\ignorespaces Model MRI spatial ``brain scan'' of the top discriminative neurons. Each row: the detection crop, the \texttt  {p3} activation (stride~8, fine spatial detail), and the \texttt  {p5} activation (stride~32, semantic depth). On the drone (a) \texttt  {p3} binds to the airframe and \texttt  {p5} forms a centred semantic blob; on the confuser (b) the same neurons fire diffusely across background structure. This activation-signature difference is what the feature-reuse filter reads.}}{68}{figure.caption.74}\protected@file@percent }
\newlabel{fig:mri_activation}{{4.8}{68}{Model MRI spatial ``brain scan'' of the top discriminative neurons. Each row: the detection crop, the \texttt {p3} activation (stride~8, fine spatial detail), and the \texttt {p5} activation (stride~32, semantic depth). On the drone (a) \texttt {p3} binds to the airframe and \texttt {p5} forms a centred semantic blob; on the confuser (b) the same neurons fire diffusely across background structure. This activation-signature difference is what the feature-reuse filter reads}{figure.caption.74}{}}
