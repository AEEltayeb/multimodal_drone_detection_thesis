\@writefile{toc}{\contentsline {paragraph}{The shipped router: dropping the reject class.}{93}{paragraph*.74}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{The grayscale hole, and why the reject class caused it.}{94}{paragraph*.75}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.4}{\ignorespaces Design-history: the grayscale \texttt  {trust\_rgb} hole was a decision-rule problem inside the four-class router, not a feature-space limit. Sweeping the per-class \texttt  {trust\_rgb} threshold $\tau $ trades precision for recall along a well-separated curve; the reject-class \texttt  {robust8} operated at $\tau {=}0.20$. The shipped \texttt  {robust8-nr} drops the reject class and removes this knob entirely (the hole cannot form without a \texttt  {reject} label). Source: \texttt  {eval/compare\_routing\_pipeline.py}.}}{94}{figure.caption.76}\protected@file@percent }
\newlabel{fig:robust8_operating}{{4.4}{94}{Design-history: the grayscale \texttt {trust\_rgb} hole was a decision-rule problem inside the four-class router, not a feature-space limit. Sweeping the per-class \texttt {trust\_rgb} threshold $\tau $ trades precision for recall along a well-separated curve; the reject-class \texttt {robust8} operated at $\tau {=}0.20$. The shipped \texttt {robust8-nr} drops the reject class and removes this knob entirely (the hole cannot form without a \texttt {reject} label). Source: \texttt {eval/compare\_routing\_pipeline.py}}{figure.caption.76}{}}
\@writefile{toc}{\contentsline {paragraph}{A dual-classifier extension (validated, not shipped).}{94}{paragraph*.77}\protected@file@percent }
