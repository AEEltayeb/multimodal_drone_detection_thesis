\@writefile{toc}{\contentsline {section}{\numberline {5.3}Model MRI Findings}{63}{section.5.3}\protected@file@percent }
\newlabel{sec:mri_findings}{{5.3}{63}{Model MRI Findings}{section.5.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5.4}{\ignorespaces Model MRI of the FT4 detector's fused \texttt  {p3}+\texttt  {p5} features on the $32{,}931$-detection base dataset (before the bird split; the production \texttt  {mlp\_v5\_v4} extends it to $33{,}272$). (a) The linear-discriminant projection separates drone (blue) from confuser (red) into two cleanly-resolved peaks at $\approx 95\%$ single-threshold accuracy. (b) Per-block ANOVA $F$-statistic: \texttt  {p5} is the dominant discriminative layer (max $F=42{,}346$, median $657$), ahead of \texttt  {p3} and the detection metadata; the confidence scalar ranks only 6th.}}{63}{figure.caption.67}\protected@file@percent }
\newlabel{fig:mri_stats}{{5.4}{63}{Model MRI of the FT4 detector's fused \texttt {p3}+\texttt {p5} features on the $32{,}931$-detection base dataset (before the bird split; the production \texttt {mlp\_v5\_v4} extends it to $33{,}272$). (a) The linear-discriminant projection separates drone (blue) from confuser (red) into two cleanly-resolved peaks at $\approx 95\%$ single-threshold accuracy. (b) Per-block ANOVA $F$-statistic: \texttt {p5} is the dominant discriminative layer (max $F=42{,}346$, median $657$), ahead of \texttt {p3} and the detection metadata; the confidence scalar ranks only 6th}{figure.caption.67}{}}
\@writefile{toc}{\contentsline {paragraph}{The signal is linear, supervised, and deep.}{63}{paragraph*.68}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {5.5}{\ignorespaces Model MRI spatial ``brain scan'' of the top discriminative neurons. Each row: the detection crop, the \texttt  {p3} activation (stride~8, fine spatial detail), and the \texttt  {p5} activation (stride~32, semantic depth). On the drone (a) \texttt  {p3} binds to the airframe and \texttt  {p5} forms a centered semantic blob; on the confuser (b) the same neurons fire diffusely across background structure. This activation-signature difference is what the feature-reuse filter reads.}}{64}{figure.caption.69}\protected@file@percent }
\newlabel{fig:mri_activation}{{5.5}{64}{Model MRI spatial ``brain scan'' of the top discriminative neurons. Each row: the detection crop, the \texttt {p3} activation (stride~8, fine spatial detail), and the \texttt {p5} activation (stride~32, semantic depth). On the drone (a) \texttt {p3} binds to the airframe and \texttt {p5} forms a centered semantic blob; on the confuser (b) the same neurons fire diffusely across background structure. This activation-signature difference is what the feature-reuse filter reads}{figure.caption.69}{}}
\@writefile{toc}{\contentsline {paragraph}{The instrument audits its own paper trail.}{64}{paragraph*.70}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {5.4}Temporal Evidence at the Segment Grain}{64}{section.5.4}\protected@file@percent }
\newlabel{sec:temporal_results}{{5.4}{64}{Temporal Evidence at the Segment Grain}{section.5.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {5.11}{\ignorespaces Segment-level (2-of-3 windows) evaluation on the real-video clips, fully out-of-distribution for every component. Filter rows use the benchmark-tuned threshold ($P(\text  {drone})\geq 0.25$). The indented row is the same shipped \texttt  {robust8-nr} composition at a video-tuned threshold ($0.05$): window recall recovers $0.489 \to 0.682$ (F1 $0.646 \to 0.797$) at a smaller confuser-fire cut ($-23\%$ vs.\ $-39\%$). The last column gives the confuser-fire cut relative to bare, and the patch arm is a per-frame approximation of the alert-gated original. The shipped \texttt  {filt$\to $clf} order and its reverse \texttt  {clf$\to $filt} coincide for the no-reject router here, because it suppresses no frame and the filter does the work either way; the reject-capable rows are reported as \texttt  {clf$\to $filt}. The grayscale channel earns its place in this dual-channel regime: when it fires on a drone clip it is almost always right (window precision $0.995$) and it barely fires on confusers ($1.8\%$ of windows), so it adds real detections at almost no false-alarm cost, and dropping it lowers window recall ($0.489 \to 0.423$).}}{65}{table.caption.71}\protected@file@percent }
\newlabel{tab:temporal_production}{{5.11}{65}{Segment-level (2-of-3 windows) evaluation on the real-video clips, fully out-of-distribution for every component. Filter rows use the benchmark-tuned threshold ($P(\text {drone})\geq 0.25$). The indented row is the same shipped \texttt {robust8-nr} composition at a video-tuned threshold ($0.05$): window recall recovers $0.489 \to 0.682$ (F1 $0.646 \to 0.797$) at a smaller confuser-fire cut ($-23\%$ vs.\ $-39\%$). The last column gives the confuser-fire cut relative to bare, and the patch arm is a per-frame approximation of the alert-gated original. The shipped \texttt {filt$\to $clf} order and its reverse \texttt {clf$\to $filt} coincide for the no-reject router here, because it suppresses no frame and the filter does the work either way; the reject-capable rows are reported as \texttt {clf$\to $filt}. The grayscale channel earns its place in this dual-channel regime: when it fires on a drone clip it is almost always right (window precision $0.995$) and it barely fires on confusers ($1.8\%$ of windows), so it adds real detections at almost no false-alarm cost, and dropping it lowers window recall ($0.489 \to 0.423$)}{table.caption.71}{}}
