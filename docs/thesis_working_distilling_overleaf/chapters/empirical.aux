\@writefile{toc}{\contentsline {subsection}{\numberline {4.1.1}Paired Drone Benchmarks: the Cost Side}{71}{subsection.4.1.1}\protected@file@percent }
\newlabel{sec:pipeline_paired}{{4.1.1}{71}{Paired Drone Benchmarks: the Cost Side}{subsection.4.1.1}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4.1}{\ignorespaces Full-pipeline ablation, Svanstr\"om paired ($n=4{,}000$ frames, even-strided across the full 28{,}710-frame set, not the first $4{,}000$; RGB @1280 / IR @640, IoP@0.5). \emph  {RGB only}/\emph  {IR only} score that detector alone against its own ground truth; every row below the second rule is trust-aware and \emph  {sums both modalities} (RGB-side scored vs RGB GT $+$ IR-side vs IR GT), so its TP/FP/FN base is both modalities' drones combined, not the frame count. \texttt  {clf} $=$ $+$trust router; \texttt  {filt} $=$ $+$per-frame filter; \texttt  {clf$\to $filt} $=$ router then filter. The shipped production cell is \texttt  {filt$\to $clf[robust8-nr]} (filter then the no-reject router; \texttt  {robust8} with the reject class is the adjacent ablation, Section~\ref {sec:classifier_results}); the pipeline \emph  {raises} recall over bare ($0.948\to 0.991$) while adding $\sim $29~pp precision. \texttt  {clf$\to $filt} is the same router in the other order (Section~\ref {sec:classifier_results} on why \texttt  {filt$\to $clf} is shipped).}}{71}{table.caption.50}\protected@file@percent }
\newlabel{tab:ablation_svanstrom}{{4.1}{71}{Full-pipeline ablation, Svanstr\"om paired ($n=4{,}000$ frames, even-strided across the full 28{,}710-frame set, not the first $4{,}000$; RGB @1280 / IR @640, IoP@0.5). \emph {RGB only}/\emph {IR only} score that detector alone against its own ground truth; every row below the second rule is trust-aware and \emph {sums both modalities} (RGB-side scored vs RGB GT $+$ IR-side vs IR GT), so its TP/FP/FN base is both modalities' drones combined, not the frame count. \texttt {clf} $=$ $+$trust router; \texttt {filt} $=$ $+$per-frame filter; \texttt {clf$\to $filt} $=$ router then filter. The shipped production cell is \texttt {filt$\to $clf[robust8-nr]} (filter then the no-reject router; \texttt {robust8} with the reject class is the adjacent ablation, Section~\ref {sec:classifier_results}); the pipeline \emph {raises} recall over bare ($0.948\to 0.991$) while adding $\sim $29~pp precision. \texttt {clf$\to $filt} is the same router in the other order (Section~\ref {sec:classifier_results} on why \texttt {filt$\to $clf} is shipped)}{table.caption.50}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4.2}{\ignorespaces Full-pipeline ablation, Anti-UAV paired ($n=4{,}000$ frames, even-strided across the 85{,}374-frame set, both modalities @640, IoU@0.5). Row conventions as in Table~\ref {tab:ablation_svanstrom} (\emph  {RGB/IR only} score one detector vs its own GT; the trust-aware rows sum both modalities). The no-harm control: every pipeline cell is within $\sim $1~pp of bare or above it, the shipped no-reject \texttt  {robust8-nr} included (this saturated surface rarely rejects, so dropping the reject class changes nothing here).}}{72}{table.caption.51}\protected@file@percent }
\newlabel{tab:ablation_antiuav}{{4.2}{72}{Full-pipeline ablation, Anti-UAV paired ($n=4{,}000$ frames, even-strided across the 85{,}374-frame set, both modalities @640, IoU@0.5). Row conventions as in Table~\ref {tab:ablation_svanstrom} (\emph {RGB/IR only} score one detector vs its own GT; the trust-aware rows sum both modalities). The no-harm control: every pipeline cell is within $\sim $1~pp of bare or above it, the shipped no-reject \texttt {robust8-nr} included (this saturated surface rarely rejects, so dropping the reject class changes nothing here)}{table.caption.51}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4.3}{\ignorespaces RQ3: single modality vs routed pipeline (bare per-modality rows vs the production cell). Each modality is scored against its own GT; the routed row is trust-aware. The modality ranking \emph  {reverses} between surfaces; the routed no-reject system matches the stronger modality on each without being told which it is.}}{74}{table.caption.52}\protected@file@percent }
\newlabel{tab:rq3}{{4.3}{74}{RQ3: single modality vs routed pipeline (bare per-modality rows vs the production cell). Each modality is scored against its own GT; the routed row is trust-aware. The modality ranking \emph {reverses} between surfaces; the routed no-reject system matches the stronger modality on each without being told which it is}{table.caption.52}{}}
\@writefile{toc}{\contentsline {paragraph}{A clean in-domain check: DUT Anti-UAV (\emph  {test split}).}{75}{paragraph*.53}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4.4}{\ignorespaces Full-pipeline ablation, DUT Anti-UAV \emph  {test split} ($n=2{,}200$ frames, $2{,}245$ GT drones, RGB \texttt  {ft4} $+$ grayscale-IR \texttt  {v3b}, both @960, IoU@0.5, trust-aware). The grayscale-IR channel is the IR detector's no-thermal \emph  {fallback} mode (thermal model on grayscale RGB), not its native thermal performance. The full test split is used (not strided). Row conventions as in Table~\ref {tab:ablation_svanstrom} (\emph  {RGB/IR only} score one detector vs its own GT; the trust-aware rows sum both modalities). Confuser-free (all-drone): filters can only delete true positives, so here the pipeline buys precision, not FP suppression. \texttt  {filt$\to $clf[robust8-nr]} (the shipped no-reject router) is the production configuration; dropping the reject class recovers the recall \texttt  {robust8} surrenders on this clean surface (at \texttt  {filt$\to $clf}, $R\,0.574\to 0.800$, F1 $0.702\to 0.835$).}}{76}{table.caption.54}\protected@file@percent }
\newlabel{tab:ablation_dut}{{4.4}{76}{Full-pipeline ablation, DUT Anti-UAV \emph {test split} ($n=2{,}200$ frames, $2{,}245$ GT drones, RGB \texttt {ft4} $+$ grayscale-IR \texttt {v3b}, both @960, IoU@0.5, trust-aware). The grayscale-IR channel is the IR detector's no-thermal \emph {fallback} mode (thermal model on grayscale RGB), not its native thermal performance. The full test split is used (not strided). Row conventions as in Table~\ref {tab:ablation_svanstrom} (\emph {RGB/IR only} score one detector vs its own GT; the trust-aware rows sum both modalities). Confuser-free (all-drone): filters can only delete true positives, so here the pipeline buys precision, not FP suppression. \texttt {filt$\to $clf[robust8-nr]} (the shipped no-reject router) is the production configuration; dropping the reject class recovers the recall \texttt {robust8} surrenders on this clean surface (at \texttt {filt$\to $clf}, $R\,0.574\to 0.800$, F1 $0.702\to 0.835$)}{table.caption.54}{}}
\@writefile{toc}{\contentsline {paragraph}{Why the shipped router drops the reject class.}{77}{paragraph*.55}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {4.1.2}Out-of-Distribution Confusers: the Benefit Side}{78}{subsection.4.1.2}\protected@file@percent }
\newlabel{sec:pipeline_confusers}{{4.1.2}{78}{Out-of-Distribution Confusers: the Benefit Side}{subsection.4.1.2}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4.5}{\ignorespaces Confuser-surface FP reduction. RGB confusers: $n=2{,}633$ (full test split) @640. IR confusers: $n=4{,}000$ of 5{,}237 (even spread) @640. Fire $=$ fraction of frames with $\geq $1 surviving detection. The shipped \texttt  {filt$\to $clf[robust8-nr]} equals \texttt  {filt only (mlp)} (and equals \texttt  {clf$\to $filt[robust8-nr]} to the digit, since a no-reject router never vetoes a confuser frame, so composition order is immaterial here); the \texttt  {robust8} ablation reaches $0.0011$ (RGB) by adding the reject net, the suppression the shipped stack trades for recall.}}{78}{table.caption.56}\protected@file@percent }
\newlabel{tab:ablation_confusers}{{4.5}{78}{Confuser-surface FP reduction. RGB confusers: $n=2{,}633$ (full test split) @640. IR confusers: $n=4{,}000$ of 5{,}237 (even spread) @640. Fire $=$ fraction of frames with $\geq $1 surviving detection. The shipped \texttt {filt$\to $clf[robust8-nr]} equals \texttt {filt only (mlp)} (and equals \texttt {clf$\to $filt[robust8-nr]} to the digit, since a no-reject router never vetoes a confuser frame, so composition order is immaterial here); the \texttt {robust8} ablation reaches $0.0011$ (RGB) by adding the reject net, the suppression the shipped stack trades for recall}{table.caption.56}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.1}{\ignorespaces Pipeline ablation at a glance, drawn for the reject-class \texttt  {robust8} cascade (the strongest-suppression configuration; the shipped no-reject \texttt  {robust8-nr} trades part of the confuser suppression for recall, Table~\ref {tab:ablation_confusers}). (a) Drone-positive paired surfaces: the router supplies most of the F1 lift and the filter finishes it; Anti-UAV confirms no-harm. Whiskers are 95\% bootstrap confidence intervals (the central range of the metric over $1{,}000$ resamples of the frames; bars whose whiskers do not overlap differ by more than sampling noise). (b) Confuser surfaces: bare $\to $ patch $\to $ \texttt  {mlp\_v5} $\to $ router $\to $ composed frame fire rates, with near-total suppression on RGB ($30.4\% \to 0.11\%$ composed) and thermal-confuser fire now largely suppressed by the thermal-native filter ($29.4\% \to 2.4\%$ composed); the shipped no-reject stack delegates suppression to the filter alone and sits at $1.4\%$ on RGB. Generated from \texttt  {tier1\_results.json} by \texttt  {thesis\_eval/gen\_ablation\_figure.py}.}}{79}{figure.caption.57}\protected@file@percent }
\newlabel{fig:pipeline_ablation}{{4.1}{79}{Pipeline ablation at a glance, drawn for the reject-class \texttt {robust8} cascade (the strongest-suppression configuration; the shipped no-reject \texttt {robust8-nr} trades part of the confuser suppression for recall, Table~\ref {tab:ablation_confusers}). (a) Drone-positive paired surfaces: the router supplies most of the F1 lift and the filter finishes it; Anti-UAV confirms no-harm. Whiskers are 95\% bootstrap confidence intervals (the central range of the metric over $1{,}000$ resamples of the frames; bars whose whiskers do not overlap differ by more than sampling noise). (b) Confuser surfaces: bare $\to $ patch $\to $ \texttt {mlp\_v5} $\to $ router $\to $ composed frame fire rates, with near-total suppression on RGB ($30.4\% \to 0.11\%$ composed) and thermal-confuser fire now largely suppressed by the thermal-native filter ($29.4\% \to 2.4\%$ composed); the shipped no-reject stack delegates suppression to the filter alone and sits at $1.4\%$ on RGB. Generated from \texttt {tier1\_results.json} by \texttt {thesis\_eval/gen\_ablation\_figure.py}}{figure.caption.57}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.1.3}Solo In-Distribution Surfaces}{80}{subsection.4.1.3}\protected@file@percent }
\newlabel{sec:pipeline_solo}{{4.1.3}{80}{Solo In-Distribution Surfaces}{subsection.4.1.3}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4.6}{\ignorespaces Solo-surface ablation (single modality vs own GT). IR test split: $n=4{,}000$ of 9{,}612; RGB test split: $n=4{,}000$ of 17{,}209; SelCom: full 311. The \texttt  {clf} rows show the router on a single live channel: the reject-class \texttt  {robust8} collapses recall (it routes against a dead second modality), while the shipped no-reject \texttt  {robust8-nr} degrades gracefully to the bare detector, which is why single-modality deployments can run the full router. The filter's in-distribution recall cost is the honest counterweight to its OOD benefit.}}{80}{table.caption.58}\protected@file@percent }
\newlabel{tab:ablation_solo}{{4.6}{80}{Solo-surface ablation (single modality vs own GT). IR test split: $n=4{,}000$ of 9{,}612; RGB test split: $n=4{,}000$ of 17{,}209; SelCom: full 311. The \texttt {clf} rows show the router on a single live channel: the reject-class \texttt {robust8} collapses recall (it routes against a dead second modality), while the shipped no-reject \texttt {robust8-nr} degrades gracefully to the bare detector, which is why single-modality deployments can run the full router. The filter's in-distribution recall cost is the honest counterweight to its OOD benefit}{table.caption.58}{}}
