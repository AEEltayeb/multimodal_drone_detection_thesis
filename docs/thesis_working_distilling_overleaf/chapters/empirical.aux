\newlabel{tab:classifiers}{{4.16}{95}{Design-evolution record: classifier comparison under the predecessor configuration (baseline RGB, v2 patch filter, \texttt {imgsz=1280}; Svanstr\"om stride 9). The split verdict between Svanstr\"om and the OOD zoo is the point}{table.caption.79}{}}
\@writefile{toc}{\contentsline {paragraph}{The surface reversal.}{95}{paragraph*.81}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.5}{\ignorespaces No trust classifier wins both surfaces. On the OOD confuser zoo \texttt  {fusion\_no\_fn\_v1.1} is far the safest (S2 fire $0.016$) but on real video it collapses drone $F1$ to $0.219$; \texttt  {sa32} inverts the ranking, dominating real-video drone $F1$ ($0.826$) at a higher zoo fire ($0.205$). This surface reversal motivated the \texttt  {sa32} working pick, later superseded by the statistically-derived \texttt  {robust6}/\texttt  {robust8} (Section~\ref {sec:feature_selection}) and the shipped no-reject \texttt  {robust8-nr} (Section~\ref {sec:classifier_results}); \texttt  {sa32}'s scene-statistic leakage is why even its wins here are not trusted to generalise.}}{96}{figure.caption.80}\protected@file@percent }
\newlabel{fig:classifier_reversal}{{4.5}{96}{No trust classifier wins both surfaces. On the OOD confuser zoo \texttt {fusion\_no\_fn\_v1.1} is far the safest (S2 fire $0.016$) but on real video it collapses drone $F1$ to $0.219$; \texttt {sa32} inverts the ranking, dominating real-video drone $F1$ ($0.826$) at a higher zoo fire ($0.205$). This surface reversal motivated the \texttt {sa32} working pick, later superseded by the statistically-derived \texttt {robust6}/\texttt {robust8} (Section~\ref {sec:feature_selection}) and the shipped no-reject \texttt {robust8-nr} (Section~\ref {sec:classifier_results}); \texttt {sa32}'s scene-statistic leakage is why even its wins here are not trusted to generalise}{figure.caption.80}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.3.4}Confuser Filter}{96}{subsection.4.3.4}\protected@file@percent }
\newlabel{sec:verifier_results}{{4.3.4}{96}{Confuser Filter}{subsection.4.3.4}{}}
\newlabel{sec:patch_threshold}{{4.3.4}{96}{Confuser Filter}{subsection.4.3.4}{}}
\newlabel{sec:patch_audit}{{4.3.4}{96}{Confuser Filter}{subsection.4.3.4}{}}
\@writefile{toc}{\contentsline {paragraph}{The patch generation: useful, gated, and bounded.}{96}{paragraph*.82}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4.17}{\ignorespaces Patch v2 catch and veto rates by bucket at \texttt  {patch\_thr=0.5} (Svanstr\"om @1280, stride 9, 3{,}190 frames, 3{,}130 detections). All three confuser buckets sit below the $0.90$ decisiveness bar.}}{97}{table.caption.83}\protected@file@percent }
\newlabel{tab:patch_audit}{{4.17}{97}{Patch v2 catch and veto rates by bucket at \texttt {patch\_thr=0.5} (Svanstr\"om @1280, stride 9, 3{,}190 frames, 3{,}130 detections). All three confuser buckets sit below the $0.90$ decisiveness bar}{table.caption.83}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.6}{\ignorespaces Patch-filter (v2) per-bucket confuser catch rate at \texttt  {patch\_thr}=0.5, against the $0.90$ ``decisiveness'' bar. Helicopters ($71\%$) and birds ($64\%$) are mid; airplanes ($52\%$, median patch probability $0.540$) are the actionable gap. All three buckets sit below the bar, the motivation for the feature-reuse successor.}}{97}{figure.caption.84}\protected@file@percent }
\newlabel{fig:patch_catchbar}{{4.6}{97}{Patch-filter (v2) per-bucket confuser catch rate at \texttt {patch\_thr}=0.5, against the $0.90$ ``decisiveness'' bar. Helicopters ($71\%$) and birds ($64\%$) are mid; airplanes ($52\%$, median patch probability $0.540$) are the actionable gap. All three buckets sit below the bar, the motivation for the feature-reuse successor}{figure.caption.84}{}}
\@writefile{toc}{\contentsline {paragraph}{The feature-reuse generation.}{97}{paragraph*.85}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{The carve-out, diagnosed and then closed.}{97}{paragraph*.88}\protected@file@percent }
\newlabel{sec:mlp_recall_drop}{{4.3.4}{97}{The carve-out, diagnosed and then closed}{paragraph*.88}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4.18}{\ignorespaces Feature-reuse filter (the production \texttt  {mlp\_v5\_v4}) vs the MobileNetV3 patch filter (v2), both on the FT4 RGB detector. $F1$ is drone-class (IoP@0.5 on Svanstr\"om/SelCom, IoU@0.5 on Anti-UAV/\texttt  {rgb\_dataset}); \emph  {halluc} is the confuser hallucination rate. \texttt  {mlp\_v5\_v4} wins every confuser-rich surface and, with the bird-split re-mine, also closes the prior \texttt  {rgb\_dataset} carve-out ($0.792\to 0.916$), now leading the patch filter there too.}}{98}{table.caption.86}\protected@file@percent }
\newlabel{tab:distill_verifier}{{4.18}{98}{Feature-reuse filter (the production \texttt {mlp\_v5\_v4}) vs the MobileNetV3 patch filter (v2), both on the FT4 RGB detector. $F1$ is drone-class (IoP@0.5 on Svanstr\"om/SelCom, IoU@0.5 on Anti-UAV/\texttt {rgb\_dataset}); \emph {halluc} is the confuser hallucination rate. \texttt {mlp\_v5\_v4} wins every confuser-rich surface and, with the bird-split re-mine, also closes the prior \texttt {rgb\_dataset} carve-out ($0.792\to 0.916$), now leading the patch filter there too}{table.caption.86}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.7}{\ignorespaces Feature-reuse filter (production \texttt  {mlp\_v5\_v4}, green) vs the MobileNetV3 patch filter (v2, blue) and the bare FT4 detector (grey), per evaluation surface. (a) Drone $F1$: \texttt  {mlp\_v5\_v4} wins Svanstr\"om and SelCom, ties saturated Anti-UAV, and (after the bird-split re-mine) recovers on the photo-style \texttt  {rgb\_dataset} split. (b) Confuser hallucination rate: lowest on every surface. Generated from \texttt  {knowledge/evals.csv}.}}{98}{figure.caption.87}\protected@file@percent }
\newlabel{fig:distill_verifier_bar}{{4.7}{98}{Feature-reuse filter (production \texttt {mlp\_v5\_v4}, green) vs the MobileNetV3 patch filter (v2, blue) and the bare FT4 detector (grey), per evaluation surface. (a) Drone $F1$: \texttt {mlp\_v5\_v4} wins Svanstr\"om and SelCom, ties saturated Anti-UAV, and (after the bird-split re-mine) recovers on the photo-style \texttt {rgb\_dataset} split. (b) Confuser hallucination rate: lowest on every surface. Generated from \texttt {knowledge/evals.csv}}{figure.caption.87}{}}
\@writefile{toc}{\contentsline {paragraph}{Held-out bird suppression (TEST split).}{99}{paragraph*.89}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.8}{\ignorespaces Design-history: the recall/precision frontier on Svanstr\"om for the no-retrain fail-open gate (with the original \texttt  {rgb\_confusers} reference, red, versus a reference expanded with held-out Svanstr\"om clutter, green), against the full-veto operating point (star) and the bare detector (square). This gate was the candidate fix \emph  {before} the bird-split re-mine closed the coverage gap directly; it is retained only as the record of why a calibration patch was inferior to fixing the training coverage. Source: \texttt  {eval/failopen\_expanded\_ref.py}.}}{100}{figure.caption.90}\protected@file@percent }
\newlabel{fig:failopen_expanded}{{4.8}{100}{Design-history: the recall/precision frontier on Svanstr\"om for the no-retrain fail-open gate (with the original \texttt {rgb\_confusers} reference, red, versus a reference expanded with held-out Svanstr\"om clutter, green), against the full-veto operating point (star) and the bare detector (square). This gate was the candidate fix \emph {before} the bird-split re-mine closed the coverage gap directly; it is retained only as the record of why a calibration patch was inferior to fixing the training coverage. Source: \texttt {eval/failopen\_expanded\_ref.py}}{figure.caption.90}{}}
\@writefile{toc}{\contentsline {paragraph}{The thermal-native IR filter.}{100}{paragraph*.91}\protected@file@percent }
\newlabel{sec:grayscale_verifier}{{4.3.4}{100}{The thermal-native IR filter}{paragraph*.91}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4.19}{\ignorespaces Thermal-native deploy filter (\texttt  {mlp\_aligned\_thermalonly}, \texttt  {conf}$=$0.40, \texttt  {thr}$=$0.05) vs the bare IR detector; FP in parentheses. CBAM is held out of training. Trained directly on thermal confuser crops, the filter cuts held-out novel-confuser FPs $48\to 6$ ($-88\%$) \emph  {and} recovers the thermal drone recall the earlier grayscale-harvested filter collapsed (CBAM recall $0.967$, no collapse); its only cost is $-3.7$~pp recall on the genuinely airplane-like \texttt  {ir\_dset} drones no threshold separates. The MobileNetV3 patch filter on the same held-out CBAM cuts only $7$ FP.}}{100}{table.caption.92}\protected@file@percent }
\newlabel{tab:ir_aligned}{{4.19}{100}{Thermal-native deploy filter (\texttt {mlp\_aligned\_thermalonly}, \texttt {conf}$=$0.40, \texttt {thr}$=$0.05) vs the bare IR detector; FP in parentheses. CBAM is held out of training. Trained directly on thermal confuser crops, the filter cuts held-out novel-confuser FPs $48\to 6$ ($-88\%$) \emph {and} recovers the thermal drone recall the earlier grayscale-harvested filter collapsed (CBAM recall $0.967$, no collapse); its only cost is $-3.7$~pp recall on the genuinely airplane-like \texttt {ir\_dset} drones no threshold separates. The MobileNetV3 patch filter on the same held-out CBAM cuts only $7$ FP}{table.caption.92}{}}
\@writefile{toc}{\contentsline {paragraph}{Operating points: the recall/false-positive dial.}{101}{paragraph*.93}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.9}{\ignorespaces Filter operating points (detection level). For each production confuser filter, drone detection recall (blue, left axis; fraction of GT-matched true-drone detections retained, pooled over the drone surfaces) and confuser fire-rate (red dashed, right axis; matching confuser surface) as the per-detection $P(\text  {drone})$ threshold varies; the shipped point ($t=0.25$ RGB, $0.05$ IR-thermal) is marked. RGB sits on a flat high-recall shoulder; the thermal-native head now suppresses thermal confusers (fire falls with the threshold; the residual is the airplane-like in-distribution fraction). Source: \texttt  {eval/filter\_operating\_sweep.py}.}}{102}{figure.caption.94}\protected@file@percent }
\newlabel{fig:filter_operating}{{4.9}{102}{Filter operating points (detection level). For each production confuser filter, drone detection recall (blue, left axis; fraction of GT-matched true-drone detections retained, pooled over the drone surfaces) and confuser fire-rate (red dashed, right axis; matching confuser surface) as the per-detection $P(\text {drone})$ threshold varies; the shipped point ($t=0.25$ RGB, $0.05$ IR-thermal) is marked. RGB sits on a flat high-recall shoulder; the thermal-native head now suppresses thermal confusers (fire falls with the threshold; the residual is the airplane-like in-distribution fraction). Source: \texttt {eval/filter\_operating\_sweep.py}}{figure.caption.94}{}}
\@writefile{toc}{\contentsline {section}{\numberline {4.4}Model MRI Findings}{102}{section.4.4}\protected@file@percent }
\newlabel{sec:mri_findings}{{4.4}{102}{Model MRI Findings}{section.4.4}{}}
\@writefile{toc}{\contentsline {paragraph}{The signal is linear, supervised, and deep.}{102}{paragraph*.96}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.10}{\ignorespaces Model MRI of the FT4 detector's fused \texttt  {p3}+\texttt  {p5} ROI features on the shipped $32{,}931$-detection corpus. (a) The linear-discriminant projection separates drone (blue) from confuser (red) into two cleanly-resolved peaks at $\approx 95\%$ single-threshold accuracy. (b) Per-block ANOVA $F$-statistic: \texttt  {p5} is the dominant discriminative layer (max $F=42{,}346$, median $657$), ahead of \texttt  {p3} and the detection metadata; the confidence scalar ranks only 6th.}}{103}{figure.caption.95}\protected@file@percent }
\newlabel{fig:mri_stats}{{4.10}{103}{Model MRI of the FT4 detector's fused \texttt {p3}+\texttt {p5} ROI features on the shipped $32{,}931$-detection corpus. (a) The linear-discriminant projection separates drone (blue) from confuser (red) into two cleanly-resolved peaks at $\approx 95\%$ single-threshold accuracy. (b) Per-block ANOVA $F$-statistic: \texttt {p5} is the dominant discriminative layer (max $F=42{,}346$, median $657$), ahead of \texttt {p3} and the detection metadata; the confidence scalar ranks only 6th}{figure.caption.95}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.11}{\ignorespaces Model MRI spatial ``brain scan'' of the top discriminative neurons. Each row: the detection crop, the \texttt  {p3} activation (stride~8, fine spatial detail), and the \texttt  {p5} activation (stride~32, semantic depth). On the drone (a) \texttt  {p3} binds to the airframe and \texttt  {p5} forms a centred semantic blob; on the confuser (b) the same neurons fire diffusely across background structure. This activation-signature difference is what the feature-reuse filter reads.}}{103}{figure.caption.97}\protected@file@percent }
\newlabel{fig:mri_activation}{{4.11}{103}{Model MRI spatial ``brain scan'' of the top discriminative neurons. Each row: the detection crop, the \texttt {p3} activation (stride~8, fine spatial detail), and the \texttt {p5} activation (stride~32, semantic depth). On the drone (a) \texttt {p3} binds to the airframe and \texttt {p5} forms a centred semantic blob; on the confuser (b) the same neurons fire diffusely across background structure. This activation-signature difference is what the feature-reuse filter reads}{figure.caption.97}{}}
\@writefile{toc}{\contentsline {paragraph}{The instrument audits its own paper trail.}{104}{paragraph*.98}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {4.5}The Grayscale Finding}{104}{section.4.5}\protected@file@percent }
\newlabel{sec:grayscale}{{4.5}{104}{The Grayscale Finding}{section.4.5}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.5.1}The Fair Three-Way Comparison}{104}{subsection.4.5.1}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4.20}{\ignorespaces The grayscale three-way on Svanstr\"om ($n=4{,}000$ of 28{,}710, IoP@0.5, bare detectors). The thermal-trained detector on grayscale-converted RGB performs within $2.7$~pp F1 of the dedicated RGB detector (with higher precision and lower recall), while the raw-RGB control isolates the grayscale conversion as the load-bearing step.}}{104}{table.caption.99}\protected@file@percent }
\newlabel{tab:gray_threeway}{{4.20}{104}{The grayscale three-way on Svanstr\"om ($n=4{,}000$ of 28{,}710, IoP@0.5, bare detectors). The thermal-trained detector on grayscale-converted RGB performs within $2.7$~pp F1 of the dedicated RGB detector (with higher precision and lower recall), while the raw-RGB control isolates the grayscale conversion as the load-bearing step}{table.caption.99}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4.21}{\ignorespaces Real-video six-mode diagnostic (the finding's discovery surface; 9 drone clips / 1{,}234 GT instances, 10 confuser clips / 1{,}250 frames, IoP@0.5). The IR-on-grayscale rows are the discovery; the raw-RGB row is the control.}}{105}{table.caption.100}\protected@file@percent }
\newlabel{tab:realvideo_master}{{4.21}{105}{Real-video six-mode diagnostic (the finding's discovery surface; 9 drone clips / 1{,}234 GT instances, 10 confuser clips / 1{,}250 frames, IoP@0.5). The IR-on-grayscale rows are the discovery; the raw-RGB row is the control}{table.caption.100}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.12}{\ignorespaces Cross-modal transfer, illustrated on one Anti-UAV night frame (each panel cropped around the drone). \emph  {Left}: the production RGB detector (\texttt  {ft4}) on the RGB frame, for reference. \emph  {Middle}: the IR detector (\texttt  {v3b}), trained zero-shot on thermal only, applied to the grayscale-converted frame; it lands the drone (IoU $0.81$ with the green GT box). \emph  {Right}: the same IR detector on the raw 3-channel RGB collapses (IoU $0.00$, no box). The transfer is carried by the single-channel intensity input; the colour information that distinguishes thermal from visible is what breaks it.}}{105}{figure.caption.101}\protected@file@percent }
\newlabel{fig:grayscale_qualitative}{{4.12}{105}{Cross-modal transfer, illustrated on one Anti-UAV night frame (each panel cropped around the drone). \emph {Left}: the production RGB detector (\texttt {ft4}) on the RGB frame, for reference. \emph {Middle}: the IR detector (\texttt {v3b}), trained zero-shot on thermal only, applied to the grayscale-converted frame; it lands the drone (IoU $0.81$ with the green GT box). \emph {Right}: the same IR detector on the raw 3-channel RGB collapses (IoU $0.00$, no box). The transfer is carried by the single-channel intensity input; the colour information that distinguishes thermal from visible is what breaks it}{figure.caption.101}{}}
