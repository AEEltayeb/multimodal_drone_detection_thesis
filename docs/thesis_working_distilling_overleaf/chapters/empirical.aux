\@writefile{toc}{\contentsline {paragraph}{The carve-out, diagnosed.}{85}{paragraph*.80}\protected@file@percent }
\newlabel{sec:mlp_recall_drop}{{4.3.4}{85}{The carve-out, diagnosed}{paragraph*.80}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.8}{\ignorespaces Why fail-open is not adopted: the recall/precision frontier on Svanstr\"om for the fail-open gate with the original \texttt  {rgb\_confusers} reference (red) versus a reference expanded with held-out Svanstr\"om clutter (green), against the full-veto operating point (star) and the bare detector (square). The full-veto point dominates at high recall; the trade is partly calibration and partly fundamental. Source: \texttt  {eval/failopen\_expanded\_ref.py}.}}{86}{figure.caption.81}\protected@file@percent }
\newlabel{fig:failopen_expanded}{{4.8}{86}{Why fail-open is not adopted: the recall/precision frontier on Svanstr\"om for the fail-open gate with the original \texttt {rgb\_confusers} reference (red) versus a reference expanded with held-out Svanstr\"om clutter (green), against the full-veto operating point (star) and the bare detector (square). The full-veto point dominates at high recall; the trade is partly calibration and partly fundamental. Source: \texttt {eval/failopen\_expanded\_ref.py}}{figure.caption.81}{}}
\@writefile{toc}{\contentsline {paragraph}{The cross-modal IR filter.}{86}{paragraph*.82}\protected@file@percent }
\newlabel{sec:grayscale_verifier}{{4.3.4}{86}{The cross-modal IR filter}{paragraph*.82}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4.19}{\ignorespaces Thermal-deploy filter (\texttt  {mlp\_v5\_ir\_aligned}, thermal scaler, \texttt  {conf}$=$0.40, \texttt  {thr}$=$0.05) vs the bare IR detector; FP in parentheses. CBAM is held out of training. The filter cuts held-out novel-confuser FPs by $69\%$ while preserving thermal drone recall in-distribution ($\Delta R$ at most $-0.007$); the MobileNetV3 patch filter on the same held-out CBAM cuts only $7$ FP.}}{86}{table.caption.83}\protected@file@percent }
\newlabel{tab:ir_aligned}{{4.19}{86}{Thermal-deploy filter (\texttt {mlp\_v5\_ir\_aligned}, thermal scaler, \texttt {conf}$=$0.40, \texttt {thr}$=$0.05) vs the bare IR detector; FP in parentheses. CBAM is held out of training. The filter cuts held-out novel-confuser FPs by $69\%$ while preserving thermal drone recall in-distribution ($\Delta R$ at most $-0.007$); the MobileNetV3 patch filter on the same held-out CBAM cuts only $7$ FP}{table.caption.83}{}}
\@writefile{toc}{\contentsline {section}{\numberline {4.4}Model MRI Findings}{87}{section.4.4}\protected@file@percent }
\newlabel{sec:mri_findings}{{4.4}{87}{Model MRI Findings}{section.4.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.9}{\ignorespaces Model MRI of the FT4 detector's fused \texttt  {p3}+\texttt  {p5} ROI features on the shipped $32{,}931$-detection corpus. (a) The linear-discriminant projection separates drone (blue) from confuser (red) into two cleanly-resolved peaks at $\approx 95\%$ single-threshold accuracy. (b) Per-block ANOVA $F$-statistic: \texttt  {p5} is the dominant discriminative layer (max $F=42{,}346$, mean $2{,}006$), ahead of \texttt  {p3} and the detection metadata; the confidence scalar ranks only 6th.}}{87}{figure.caption.84}\protected@file@percent }
\newlabel{fig:mri_stats}{{4.9}{87}{Model MRI of the FT4 detector's fused \texttt {p3}+\texttt {p5} ROI features on the shipped $32{,}931$-detection corpus. (a) The linear-discriminant projection separates drone (blue) from confuser (red) into two cleanly-resolved peaks at $\approx 95\%$ single-threshold accuracy. (b) Per-block ANOVA $F$-statistic: \texttt {p5} is the dominant discriminative layer (max $F=42{,}346$, mean $2{,}006$), ahead of \texttt {p3} and the detection metadata; the confidence scalar ranks only 6th}{figure.caption.84}{}}
\@writefile{toc}{\contentsline {paragraph}{The signal is linear, supervised, and deep.}{87}{paragraph*.85}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.10}{\ignorespaces Model MRI spatial ``brain scan'' of the top discriminative neurons. Each row: the detection crop, the \texttt  {p3} activation (stride~8, fine spatial detail), and the \texttt  {p5} activation (stride~32, semantic depth). On the drone (a) \texttt  {p3} binds to the airframe and \texttt  {p5} forms a centred semantic blob; on the confuser (b) the same neurons fire diffusely across background structure. This activation-signature difference is what the feature-reuse filter reads.}}{88}{figure.caption.86}\protected@file@percent }
\newlabel{fig:mri_activation}{{4.10}{88}{Model MRI spatial ``brain scan'' of the top discriminative neurons. Each row: the detection crop, the \texttt {p3} activation (stride~8, fine spatial detail), and the \texttt {p5} activation (stride~32, semantic depth). On the drone (a) \texttt {p3} binds to the airframe and \texttt {p5} forms a centred semantic blob; on the confuser (b) the same neurons fire diffusely across background structure. This activation-signature difference is what the feature-reuse filter reads}{figure.caption.86}{}}
\@writefile{toc}{\contentsline {paragraph}{Cross-modal alignment is an affine offset.}{88}{paragraph*.87}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {4.11}{\ignorespaces Grayscale$\leftrightarrow $thermal feature alignment in the IR detector. (A) After a per-modality z-score, thermal and grayscale drones land in the same region of the drone-vs-confuser discriminant axis, and likewise for confusers: the modalities are interchangeable up to an affine offset. (B) Grayscale-trained confuser-filter transfer to thermal rises from chance ($0.500$) to near the within-thermal ceiling ($0.919$ vs $0.974$) once the offset is removed; CORAL ($0.707$) under-performs the simpler z-score.}}{89}{figure.caption.88}\protected@file@percent }
\newlabel{fig:ir_gray_align}{{4.11}{89}{Grayscale$\leftrightarrow $thermal feature alignment in the IR detector. (A) After a per-modality z-score, thermal and grayscale drones land in the same region of the drone-vs-confuser discriminant axis, and likewise for confusers: the modalities are interchangeable up to an affine offset. (B) Grayscale-trained confuser-filter transfer to thermal rises from chance ($0.500$) to near the within-thermal ceiling ($0.919$ vs $0.974$) once the offset is removed; CORAL ($0.707$) under-performs the simpler z-score}{figure.caption.88}{}}
\@writefile{toc}{\contentsline {paragraph}{The instrument audits its own paper trail.}{89}{paragraph*.89}\protected@file@percent }
\@writefile{toc}{\contentsline {section}{\numberline {4.5}The Grayscale Finding}{89}{section.4.5}\protected@file@percent }
\newlabel{sec:grayscale}{{4.5}{89}{The Grayscale Finding}{section.4.5}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {4.5.1}The Fair Three-Way Comparison}{89}{subsection.4.5.1}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {4.20}{\ignorespaces The grayscale three-way on Svanstr\"om ($n=4{,}000$ of 28{,}710, IoP@0.5, bare detectors). The thermal-trained detector on grayscale-converted RGB performs within $2.7$~pp F1 of the dedicated RGB detector (with higher precision and lower recall), while the raw-RGB control isolates the grayscale conversion as the load-bearing step.}}{90}{table.caption.90}\protected@file@percent }
\newlabel{tab:gray_threeway}{{4.20}{90}{The grayscale three-way on Svanstr\"om ($n=4{,}000$ of 28{,}710, IoP@0.5, bare detectors). The thermal-trained detector on grayscale-converted RGB performs within $2.7$~pp F1 of the dedicated RGB detector (with higher precision and lower recall), while the raw-RGB control isolates the grayscale conversion as the load-bearing step}{table.caption.90}{}}
\@writefile{lot}{\contentsline {table}{\numberline {4.21}{\ignorespaces Real-video six-mode diagnostic (the finding's discovery surface; 9 drone clips / 1{,}234 GT instances, 10 confuser clips / 1{,}250 frames, IoP@0.5). The IR-on-grayscale rows are the discovery; the raw-RGB row is the control.}}{90}{table.caption.91}\protected@file@percent }
\newlabel{tab:realvideo_master}{{4.21}{90}{Real-video six-mode diagnostic (the finding's discovery surface; 9 drone clips / 1{,}234 GT instances, 10 confuser clips / 1{,}250 frames, IoP@0.5). The IR-on-grayscale rows are the discovery; the raw-RGB row is the control}{table.caption.91}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {4.12}{\ignorespaces Cross-modal transfer, illustrated on one Anti-UAV night frame (each panel cropped around the drone). \emph  {Left}: the production RGB detector (\texttt  {ft4}) on the RGB frame, for reference. \emph  {Middle}: the IR detector (\texttt  {v3b}), trained zero-shot on thermal only, applied to the grayscale-converted frame; it lands the drone (IoU $0.81$ with the green GT box). \emph  {Right}: the same IR detector on the raw 3-channel RGB collapses (IoU $0.00$, no box). The transfer is carried by the single-channel intensity input; the colour information that distinguishes thermal from visible is what breaks it.}}{91}{figure.caption.92}\protected@file@percent }
\newlabel{fig:grayscale_qualitative}{{4.12}{91}{Cross-modal transfer, illustrated on one Anti-UAV night frame (each panel cropped around the drone). \emph {Left}: the production RGB detector (\texttt {ft4}) on the RGB frame, for reference. \emph {Middle}: the IR detector (\texttt {v3b}), trained zero-shot on thermal only, applied to the grayscale-converted frame; it lands the drone (IoU $0.81$ with the green GT box). \emph {Right}: the same IR detector on the raw 3-channel RGB collapses (IoU $0.00$, no box). The transfer is carried by the single-channel intensity input; the colour information that distinguishes thermal from visible is what breaks it}{figure.caption.92}{}}
