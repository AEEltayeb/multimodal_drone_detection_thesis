\@writefile{lof}{\contentsline {figure}{\numberline {6.6}{\ignorespaces Reminder placeholder: the production per-frame \texttt  {mlp\_v5} verifier has component-level evidence (\S  \ref {sec:distill_verifier}) but has not yet been run through this full real-video cascade; the numbers in this section use its patch-verifier predecessor.}}{107}{figure.caption.85}\protected@file@percent }
\newlabel{fig:mlp_pipeline_placeholder}{{6.6}{107}{Reminder placeholder: the production per-frame \texttt {mlp\_v5} verifier has component-level evidence (\S \ref {sec:distill_verifier}) but has not yet been run through this full real-video cascade; the numbers in this section use its patch-verifier predecessor}{figure.caption.85}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.5.1}Setup}{107}{subsection.6.5.1}\protected@file@percent }
\@writefile{lof}{\contentsline {figure}{\numberline {6.7}{\ignorespaces The cascade made concrete on two sequences. Top row: a Svanstr\"om sequence with a small drone and a bird; bottom row: a YouTube clip from \texttt  {drone\_seagull\_attack}. Each row shows what each stage removes and what survives.}}{108}{figure.caption.86}\protected@file@percent }
\newlabel{fig:cascade_per_stage}{{6.7}{108}{The cascade made concrete on two sequences. Top row: a Svanstr\"om sequence with a small drone and a bird; bottom row: a YouTube clip from \texttt {drone\_seagull\_attack}. Each row shows what each stage removes and what survives}{figure.caption.86}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.5.2}Reading per-frame metrics is misleading}{108}{subsection.6.5.2}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {6.11}{\ignorespaces Per-frame drone metrics, Stage-1 RGB versus + classifier merging. The classifier merges RGB and IR detections per its trust label; when both modalities fire on the same drone frame, the resulting joint set inflates the per-frame FP count even when both detections are correct. The per-frame grain misrepresents what production does. Source: \textsc  {Ledger}~\S  9.5.}}{109}{table.caption.87}\protected@file@percent }
\newlabel{tab:cascade_perframe}{{6.11}{109}{Per-frame drone metrics, Stage-1 RGB versus + classifier merging. The classifier merges RGB and IR detections per its trust label; when both modalities fire on the same drone frame, the resulting joint set inflates the per-frame FP count even when both detections are correct. The per-frame grain misrepresents what production does. Source: \textsc {Ledger}~\S 9.5}{table.caption.87}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6.8}{\ignorespaces Why per-frame metrics mislead. For each RGB variant, drone $F1$ \emph  {drops} when the trust classifier merges modalities at the per-frame grain, then \emph  {recovers} (and exceeds the RGB stage) once the $3$-frame temporal smoother resolves alerts at the segment grain. The deployed system fires on segments, not frames, so the segment values are the production-relevant ones. Source: \textsc  {Ledger}~\S  9.5.}}{109}{figure.caption.88}\protected@file@percent }
\newlabel{fig:perframe_segment}{{6.8}{109}{Why per-frame metrics mislead. For each RGB variant, drone $F1$ \emph {drops} when the trust classifier merges modalities at the per-frame grain, then \emph {recovers} (and exceeds the RGB stage) once the $3$-frame temporal smoother resolves alerts at the segment grain. The deployed system fires on segments, not frames, so the segment values are the production-relevant ones. Source: \textsc {Ledger}~\S 9.5}{figure.caption.88}{}}
\@writefile{toc}{\contentsline {subsection}{\numberline {6.5.3}Segment-level metrics: cascade earns its budget}{110}{subsection.6.5.3}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {6.12}{\ignorespaces Segment-level (3-frame window) drone $F1$ and all-confuser FPR. \emph  {Drone $F1$ cascade}: the segment-level drone $F1$ after temporal + patch veto. \emph  {Confuser FPR cascade}: the segment-level fire rate on confuser-only videos after the same stack. \emph  {Cut}: relative reduction from Stage-1 RGB. The cascade absorbs detector variance, post-cascade $F1$ spans $0.770$--$0.826$ versus the Stage-1 spread of $0.605$--$0.760$. Source: \textsc  {Ledger}~\S  9.5.}}{110}{table.caption.89}\protected@file@percent }
\newlabel{tab:cascade_segment}{{6.12}{110}{Segment-level (3-frame window) drone $F1$ and all-confuser FPR. \emph {Drone $F1$ cascade}: the segment-level drone $F1$ after temporal + patch veto. \emph {Confuser FPR cascade}: the segment-level fire rate on confuser-only videos after the same stack. \emph {Cut}: relative reduction from Stage-1 RGB. The cascade absorbs detector variance, post-cascade $F1$ spans $0.770$--$0.826$ versus the Stage-1 spread of $0.605$--$0.760$. Source: \textsc {Ledger}~\S 9.5}{table.caption.89}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6.9}{\ignorespaces Segment-level drone $F1$ and confuser FPR, Stage-1 RGB (grey) versus the full cascade, for the four RGB variants on the real-video diagnostic. (a) The cascade \emph  {lifts} drone $F1$ for every variant ($+6.6$ to $+16.5$~pp). (b) It \emph  {cuts} confuser FPR by $39$--$81\%$. The two effects together compress the Stage-1 spread (15.5~pp $F1$ / 51.3~pp FPR) to $5.6$~pp / $4.3$~pp. Source: \textsc  {Ledger}~\S  9.5.}}{110}{figure.caption.90}\protected@file@percent }
\newlabel{fig:cascade_segment_fig}{{6.9}{110}{Segment-level drone $F1$ and confuser FPR, Stage-1 RGB (grey) versus the full cascade, for the four RGB variants on the real-video diagnostic. (a) The cascade \emph {lifts} drone $F1$ for every variant ($+6.6$ to $+16.5$~pp). (b) It \emph {cuts} confuser FPR by $39$--$81\%$. The two effects together compress the Stage-1 spread (15.5~pp $F1$ / 51.3~pp FPR) to $5.6$~pp / $4.3$~pp. Source: \textsc {Ledger}~\S 9.5}{figure.caption.90}{}}
\@writefile{toc}{\contentsline {paragraph}{The cascade compresses the Stage-1 spread.}{110}{paragraph*.91}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{The cascade is most valuable on the worst Stage-1 detector.}{111}{paragraph*.92}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Drone-$F1$ cost is small at the alert grain.}{111}{paragraph*.93}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {6.5.4}Per-category cascade suppression}{111}{subsection.6.5.4}\protected@file@percent }
\newlabel{sec:realvideo_percategory}{{6.5.4}{111}{Per-category cascade suppression}{subsection.6.5.4}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6.13}{\ignorespaces Segment-level confuser FPR after temporal + patch veto, broken out by category. The cascade earns its keep on birds (a 45$\times $ suppression for \texttt  {selcom\_1280}) and is essentially inert on airplanes. Source: \textsc  {Ledger}~\S  9.5.9.}}{112}{table.caption.94}\protected@file@percent }
\newlabel{tab:cascade_percategory}{{6.13}{112}{Segment-level confuser FPR after temporal + patch veto, broken out by category. The cascade earns its keep on birds (a 45$\times $ suppression for \texttt {selcom\_1280}) and is essentially inert on airplanes. Source: \textsc {Ledger}~\S 9.5.9}{table.caption.94}{}}
\@writefile{toc}{\contentsline {paragraph}{The cascade's value is concentrated on birds, exactly as designed.}{112}{paragraph*.95}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{The cascade is essentially inert on airplanes.}{112}{paragraph*.96}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{Helicopters fall in between.}{113}{paragraph*.97}\protected@file@percent }
\@writefile{toc}{\contentsline {subsection}{\numberline {6.5.5}Classifier choice on real video}{113}{subsection.6.5.5}\protected@file@percent }
\newlabel{sec:realvideo_classifier}{{6.5.5}{113}{Classifier choice on real video}{subsection.6.5.5}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6.14}{\ignorespaces Segment-level drone $F1$ under three classifiers on the real-video diagnostic. sa32 dominates for every RGB variant; fnfn rejects 85\% of correct RGB drone TPs and collapses segment $R$ to $\leq 0.128$. Source: \textsc  {Ledger}~\S  9.5.8.}}{113}{table.caption.98}\protected@file@percent }
\newlabel{tab:cascade_classifier_drone}{{6.14}{113}{Segment-level drone $F1$ under three classifiers on the real-video diagnostic. sa32 dominates for every RGB variant; fnfn rejects 85\% of correct RGB drone TPs and collapses segment $R$ to $\leq 0.128$. Source: \textsc {Ledger}~\S 9.5.8}{table.caption.98}{}}
\@writefile{toc}{\contentsline {paragraph}{The Svanstr\"om classifier ordering is partly Svanstr\"om-specific.}{113}{paragraph*.101}\protected@file@percent }
\@writefile{lot}{\contentsline {table}{\numberline {6.15}{\ignorespaces Segment-level all-confuser FPR under three classifiers. fnfn cuts the FPR to 1.2--2.4\%, but at the drone-recall cost shown in Table~\ref {tab:cascade_classifier_drone}. Source: \textsc  {Ledger}~\S  9.5.8.}}{114}{table.caption.99}\protected@file@percent }
\newlabel{tab:cascade_classifier_fpr}{{6.15}{114}{Segment-level all-confuser FPR under three classifiers. fnfn cuts the FPR to 1.2--2.4\%, but at the drone-recall cost shown in Table~\ref {tab:cascade_classifier_drone}. Source: \textsc {Ledger}~\S 9.5.8}{table.caption.99}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6.10}{\ignorespaces No trust classifier wins both surfaces. On the OOD confuser zoo \texttt  {fusion\_no\_fn\_v1.1} is far the safest (S2 fire $0.016$) but on real video it collapses drone $F1$ to $0.219$; \texttt  {sa32} inverts the ranking, dominating real-video drone $F1$ ($0.826$) at a higher zoo fire ($0.205$). The Svanstr\"om/zoo ordering does not by itself select the production classifier --- this surface reversal motivated the \texttt  {sa32} working pick, later superseded by the statistically-derived \texttt  {robust6}/\texttt  {robust8} (\S  \ref {sec:feature_selection}). Source: \textsc  {Ledger}~\S  7, \S  9.5.8.}}{114}{figure.caption.100}\protected@file@percent }
\newlabel{fig:classifier_reversal}{{6.10}{114}{No trust classifier wins both surfaces. On the OOD confuser zoo \texttt {fusion\_no\_fn\_v1.1} is far the safest (S2 fire $0.016$) but on real video it collapses drone $F1$ to $0.219$; \texttt {sa32} inverts the ranking, dominating real-video drone $F1$ ($0.826$) at a higher zoo fire ($0.205$). The Svanstr\"om/zoo ordering does not by itself select the production classifier --- this surface reversal motivated the \texttt {sa32} working pick, later superseded by the statistically-derived \texttt {robust6}/\texttt {robust8} (\S \ref {sec:feature_selection}). Source: \textsc {Ledger}~\S 7, \S 9.5.8}{figure.caption.100}{}}
\@writefile{toc}{\contentsline {paragraph}{fnfn is too conservative for real-video deployment.}{115}{paragraph*.102}\protected@file@percent }
\@writefile{toc}{\contentsline {paragraph}{control40 buys nothing over sa32.}{115}{paragraph*.103}\protected@file@percent }
