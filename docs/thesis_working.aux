\newlabel{sec:grayscale_verifier}{{6.4.6}{103}{From Cross-Modal Transfer to a Deployable Thermal Verifier}{subsection.6.4.6}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6.9}{\ignorespaces Thermal-deploy verifier (\texttt  {mlp\_v5\_ir\_aligned}, scaler \texttt  {mlp\_aligned.pt}, \texttt  {conf}$=$0.40, \texttt  {thr}$=$0.05) vs the bare IR detector; FP in parentheses. CBAM is held out of training. The verifier cuts held-out novel-confuser false positives by $69\%$ ($48\to 15$, $+0.147$~$F1$) while preserving thermal drone recall on the in-distribution surfaces ($\Delta R$ at most $-0.007$); the held-out CBAM row itself trades $-0.050$ drone recall, the residual cost on a novel confuser domain. The MobileNetV3 patch verifier on the same held-out CBAM cuts only $7$ FP. Source: \textsc  {Ledger}~ir-grayscale-harvest-solves-thermal-verifier, ir-recall-fixed-by-drone-diversity.}}{104}{table.caption.83}\protected@file@percent }
\newlabel{tab:ir_aligned}{{6.9}{104}{Thermal-deploy verifier (\texttt {mlp\_v5\_ir\_aligned}, scaler \texttt {mlp\_aligned.pt}, \texttt {conf}$=$0.40, \texttt {thr}$=$0.05) vs the bare IR detector; FP in parentheses. CBAM is held out of training. The verifier cuts held-out novel-confuser false positives by $69\%$ ($48\to 15$, $+0.147$~$F1$) while preserving thermal drone recall on the in-distribution surfaces ($\Delta R$ at most $-0.007$); the held-out CBAM row itself trades $-0.050$ drone recall, the residual cost on a novel confuser domain. The MobileNetV3 patch verifier on the same held-out CBAM cuts only $7$ FP. Source: \textsc {Ledger}~ir-grayscale-harvest-solves-thermal-verifier, ir-recall-fixed-by-drone-diversity}{table.caption.83}{}}
\@writefile{lot}{\contentsline {table}{\numberline {6.10}{\ignorespaces Grayscale-deploy verifier (same net, scaler \texttt  {mlp\_aligned\_gray.pt}, \texttt  {conf}$=$0.25, \texttt  {thr}$=$0.25); FP in parentheses. The aligned verifier matches the dedicated grayscale-only filter's confuser cut at half the recall loss. Source: \textsc  {Ledger}~ir-grayscale-harvest-solves-thermal-verifier.}}{105}{table.caption.84}\protected@file@percent }
\newlabel{tab:ir_aligned_gray}{{6.10}{105}{Grayscale-deploy verifier (same net, scaler \texttt {mlp\_aligned\_gray.pt}, \texttt {conf}$=$0.25, \texttt {thr}$=$0.25); FP in parentheses. The aligned verifier matches the dedicated grayscale-only filter's confuser cut at half the recall loss. Source: \textsc {Ledger}~ir-grayscale-harvest-solves-thermal-verifier}{table.caption.84}{}}
